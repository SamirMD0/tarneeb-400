# ===================
# Environment
# ===================
NODE_ENV=development

# ===================
# Server
# ===================
PORT=5000

# ===================
# MongoDB
# ===================
# Local (Docker)
MONGO_URI=mongodb://mongo:27017/cards_game

# Production (MongoDB Atlas) - uncomment for prod
# MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority

# Phase 15: MongoDB Connection Pool Configuration
MONGO_MAX_POOL_SIZE=10
MONGO_MIN_POOL_SIZE=2
MONGO_RETRY_WRITES=true
MONGO_WRITE_CONCERN=majority

# ===================
# Redis
# ===================
# Local (Docker)
# REDIS_URL=redis://redis:6379
REDIS_URL=redis://localhost:6379


# Production (Upstash with TLS) - uncomment for prod
# REDIS_URL=rediss://<username>:<password>@<endpoint>.upstash.io:6379

# ===================
# CORS
# ===================
# REQUIRED: Set to your frontend domain (e.g., http://localhost:3000 or https://example.com)
# NEVER use '*' in production — it allows CSRF attacks from any origin
CORS_ORIGIN=http://localhost:3000

# ===================
# Phase 19: Rate Limiting
# ===================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
ROOM_CREATION_LIMIT=3

# ===================
# Phase 19: Security
# ===================
ENABLE_STRICT_VALIDATION=true
LOG_ERRORS=true
# NEVER set to true in production
EXPOSE_STACK_TRACES=false

# ===================
# Phase 19: JWT Security
# ===================
# REQUIRED: Set to a strong random string (minimum 32 characters)
# Generate with: openssl rand -base64 32
JWT_SECRET=your-secret-key-here-minimum-32-characters-required
JWT_EXPIRES_IN=7d
